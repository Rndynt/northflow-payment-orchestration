# ──────────────────────────────────────────────────────────────────────────────
# Payment Orchestration Service — Environment Variables
# Phase 8K: Deployment Readiness
#
# Copy to .env and fill in values for your environment.
# DO NOT commit .env to version control.
# DO NOT store raw API keys or secrets in this file — use credentialsRef instead.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=development

# Port for the standalone service (default: 5100)
# Avoid 5000 — reserved for the AuraPoS API.
PAYMENT_ORCHESTRATION_SERVICE_PORT=5100

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# The service uses PAYMENT_ORCHESTRATION_DATABASE_URL first, then falls back to DATABASE_URL.
PAYMENT_ORCHESTRATION_DATABASE_URL=postgresql://user:password@localhost:5432/payment_orchestration_db
# DATABASE_URL=postgresql://user:password@localhost:5432/payment_orchestration_db

# ── Service Token ─────────────────────────────────────────────────────────────

# Service-to-service authentication token.
# Required for all /v1/... routes except /v1/webhooks/:provider.
# Use a long random string in production (e.g. openssl rand -hex 32).
PAYMENT_ORCHESTRATION_SERVICE_TOKEN=replace-with-strong-random-token

# Legacy alias — kept for monorepo backwards compat. Prefer PAYMENT_ORCHESTRATION_SERVICE_TOKEN.
# PAYMENT_ENGINE_SERVICE_TOKEN=replace-with-strong-random-token

# ── FakeGateway Webhook ───────────────────────────────────────────────────────

# HMAC-SHA256 secret for verifying FakeGateway webhook signatures.
# Required in production. Optional in development (unsigned webhooks accepted).
# Example: openssl rand -hex 32
PAYMENT_ORCHESTRATION_FAKEGATEWAY_WEBHOOK_SECRET=replace-with-strong-random-secret

# ── Xendit Sandbox (optional) ─────────────────────────────────────────────────

# Set to 'true' to enable Xendit HTTP calls. Default: false.
PAYMENT_ORCHESTRATION_XENDIT_SANDBOX_ENABLED=false

# Xendit API base URL. Default: https://api.xendit.co
PAYMENT_ORCHESTRATION_XENDIT_BASE_URL=https://api.xendit.co

# Xendit callback verification token (x-callback-token header).
# Do NOT store the raw key here in production — reference a secret manager key name instead.
PAYMENT_ORCHESTRATION_XENDIT_CALLBACK_TOKEN=replace-with-xendit-callback-token

# ── Xendit Provider Account Credentials (credentialsRef) ──────────────────────
# When creating a provider account, set credentialsRef to the ENV VAR NAME
# (not the raw secret) that contains the Xendit secret key.
# The service reads process.env[credentialsRef] at runtime.
# Example credentialsRef value stored in DB: "PAYMENT_ORCHESTRATION_XENDIT_SANDBOX_SECRET_KEY"
# Then set this env var:
PAYMENT_ORCHESTRATION_XENDIT_SANDBOX_SECRET_KEY=replace-with-xendit-sandbox-secret-key
