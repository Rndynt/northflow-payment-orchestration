{
  "name": "@northflow/payment-orchestration-service",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json src/index.ts",
    "start": "NODE_ENV=production tsx --tsconfig tsconfig.json src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx --tsconfig tsconfig.json src/workers/run.ts",
    "db:migrate": "npx drizzle-kit migrate --config=drizzle.config.ts",
    "db:generate": "npx drizzle-kit generate --config=drizzle.config.ts",
    "nf:admin": "tsx --tsconfig tsconfig.json src/cli/nf-admin.ts"
  },
  "dependencies": {
    "@northflow/payment-orchestration-core": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "express": "^4.21.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "20.16.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.30.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "payment-orchestration",
    "service",
    "northflow"
  ],
  "license": "ISC"
}
