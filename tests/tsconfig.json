{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": "..",
    "paths": {
      "@northflow/payment-orchestration-core": ["packages/core/src"],
      "@northflow/payment-orchestration-core/*": ["packages/core/src/*"],
      "@northflow/payment-orchestration-client-sdk": ["packages/client-sdk/src"],
      "@northflow/payment-orchestration-client-sdk/*": ["packages/client-sdk/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "../packages/core/src/**/*.ts",
    "../packages/client-sdk/src/**/*.ts",
    "../apps/service/src/**/*.ts",
    "../scripts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
