{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@northflow/payment-orchestration-core": [
        "../../packages/core/src"
      ],
      "@northflow/payment-orchestration-core/*": [
        "../../packages/core/src/*"
      ]
    },
    "lib": [
      "ES2020",
      "DOM"
    ]
  },
  "include": [
    "src/**/*.ts",
    "../../packages/core/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
