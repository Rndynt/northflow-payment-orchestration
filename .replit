modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PAYMENT_ORCHESTRATION_SERVICE_PORT = "3001"
PAYMENT_ORCHESTRATION_XENDIT_SANDBOX_ENABLED = "false"
PAYMENT_ORCHESTRATION_XENDIT_BASE_URL = "https://api.xendit.co"
NEXT_PUBLIC_REPLIT_DEV_DOMAIN = "82f57244-df1d-4d23-8603-2f8abca41662-00-1lmj98ae8gip8.pike.replit.dev"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start dashboard"

[[workflows.workflow]]
name = "Start service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev:service"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @northflow/payment-orchestration-dashboard dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["pnpm", "start:service"]
